FROM python:3.12-bullseye

WORKDIR /code

# PostgreSQL 17 client + boshqa paketlar
RUN sh -c 'echo "deb http://apt.postgresql.org/pub/repos/apt bullseye-pgdg main" > /etc/apt/sources.list.d/pgdg.list' && \
    wget --quiet -O - https://www.postgresql.org/media/keys/ACCC4CF8.asc | apt-key add - && \
    apt-get update && \
    apt-get install -y \
    gdal-bin \
    libgdal-dev \
    python3-gdal \
    libgeos-dev \
    libproj-dev \
    g++ \
    make \
    wget \
    libfontconfig \
    libxrender1 \
    libjpeg-dev \
    xfonts-base \
    postgresql-client-17 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Avval faqat requirements — kod o'zgarganda pip qayta ishlamasligi uchun
# (Railway builderi --mount=type=cache ni id'siz qabul qilmaydi, shuning
# uchun cache mount ishlatilmaydi)
COPY requirements.txt /code/requirements.txt
RUN python3 -m pip install --no-cache-dir -r requirements.txt

COPY ./ /code

CMD ["sh", "./resources/scripts/entrypoint.sh"]
